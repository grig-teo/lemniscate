# Backend configuration — copy to `backend/.env` and fill in real values.
# `.env` is gitignored; never commit secrets.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- URLs ---
FRONTEND_URL=http://localhost:8080
# Public URL of this backend (used for OAuth callbacks)
BACKEND_URL=http://localhost:3000
# Base URL for OAuth callbacks — the backend appends `/{provider}/callback`,
# so register e.g. http://localhost:3000/api/auth/github/callback at the provider.
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth

# --- Database (overridden by docker-compose; used for local dev) ---
DATABASE_URL=postgresql://lemniscate:lemniscate@localhost:5432/lemniscate

# --- Redis (BullMQ queue for the agent loop) ---
REDIS_URL=redis://localhost:6379

# --- Security ---
# Secret for signing session JWTs
JWT_SECRET=change-me-to-a-long-random-string
# 64-char hex (32 bytes) key for AES-256-GCM encryption of stored LLM API keys
ENCRYPTION_KEY=change-me-to-64-hex-chars

# --- GitHub OAuth App (https://github.com/settings/developers) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitVerse OAuth App ---
GITVERSE_CLIENT_ID=
GITVERSE_CLIENT_SECRET=
GITVERSE_BASE_URL=https://gitverse.ru

# --- GitLab OAuth App (optional) ---
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# --- Agent loop ---
# Directory (inside the worker container) where repos are cloned
AGENT_WORKDIR=/tmp/lemniscate-repos
# Default branch prefix for agent-generated PRs
AGENT_BRANCH_PREFIX=lemniscate/
